local function AddMenuButton(text, hub)
    local row = Instance.new("Frame", MenuContent)
    row.Size = UDim2.new(1, -8, 0, 40)
    row.BackgroundColor3 = C.DarkRow
    row.BackgroundTransparency = 0.3
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    
    local label = Instance.new("TextLabel", row)
    label.Size = UDim2.new(0, 100, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = C.White
    label.Font = Enum.Font.GothamBold
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local isHubVisible = hub.Frame.Visible
    
    local toggleBtn = Instance.new("TextButton", row)
    toggleBtn.Size = UDim2.new(0, 50, 0, 24)
    toggleBtn.Position = UDim2.new(1, -62, 0.5, -12)
    toggleBtn.BackgroundColor3 = isHubVisible and C.Gray or C.TogOff
    toggleBtn.Text = isHubVisible and "HIDE" or "SHOW"
    toggleBtn.TextColor3 = C.White
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.TextSize = 11
    toggleBtn.AutoButtonColor = false
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 6)
    
    toggleBtn.MouseButton1Click:Connect(function()
        local newState = not hub.Frame.Visible
        hub.Frame.Visible = newState
        toggleBtn.BackgroundColor3 = newState and C.Gray or C.TogOff
        toggleBtn.Text = newState and "HIDE" or "SHOW"
    end)
    
    return row
end

