local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/oday018/Steal-A-Brainrot-Script-LUX/refs/heads/main/GUL.lua"))()

-- إضافة تبويب جديد
local MyTab = Library:AddTab("MY TAB")

-- إضافة قسم
Library:AddSection(MyTab, "  MY SECTION", 1)

-- إضافة Toggle
local myToggle = Library:AddToggle(MyTab, "My Toggle", 2, function(state)
    print("Toggle is now:", state)
end, false)

-- إضافة زر
Library:AddButton(MyTab, "CLICK ME", 3, function()
    print("Button clicked!")
end)

-- إضافة مدخل رقمي
Library:AddNumberInput(MyTab, "Speed", 100, 4, function(value)
    print("Speed set to:", value)
end)

-- إضافة زر موبايل
Library:AddMobileButton("CUSTOM", -120, -350, "My Toggle", function()
    local state = Library:GetToggleState("My Toggle")
    Library:SetToggleState("My Toggle", not state)
end)

-- التحكم في القائمة
Library:Show()
Library:Hide()
Library:Toggle()
