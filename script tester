        list.Visible = not list.Visible
        if list.Visible then
            if ActiveDropdown and ActiveDropdown ~= list then
                ActiveDropdown.Visible = false
            end
            ActiveDropdown = list
            list.ZIndex = 100
        end
    end
    
    btn.MouseButton1Click:Connect(updateList)
    
